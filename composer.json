{
  "name": "yoosuf/docit",
  "description": "Laravel package for production document generation from DOCX and PDF templates with idempotency, queues, and template inspection.",
  "type": "library",
  "keywords": [
    "laravel",
    "document-generation",
    "pdf",
    "docx",
    "templating",
    "idempotency",
    "queue",
    "api"
  ],
  "license": "MIT",
  "homepage": "https://github.com/yoosuf/dockit",
  "authors": [
    {
      "name": "Yoosuf"
    }
  ],
  "support": {
    "issues": "https://github.com/yoosuf/dockit/issues",
    "source": "https://github.com/yoosuf/dockit"
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/queue": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "mikehaertl/php-pdftk": "^0.14.4",
    "phpoffice/phpword": "^1.4",
    "symfony/process": "^6.4|^7.0"
  },
  "autoload": {
    "psr-4": {
      "Yoosuf\\Document\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Yoosuf\\Document\\DocumentServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
